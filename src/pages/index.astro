---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { SITE } from '../config';
import { getPublishedPosts } from '../utils/posts';

const posts = (await getPublishedPosts()).slice(0, 5);
---

<BaseLayout>
  {/* ─── Hero ─────────────────────────────────────────────── */}
  <section class="relative pb-10 pt-2 sm:pt-6">
    <h1
      class="font-bold uppercase leading-[0.85] tracking-tighter"
      style="font-size: var(--text-mega)"
    >
      <span class="block">It works.</span>
      <span class="block text-[var(--accent)] hero-write">But why?</span>
    </h1>

    <p class="mt-6 max-w-xl text-xl leading-relaxed text-[var(--fg-muted)]">
      {SITE.description}
    </p>

    <div class="mt-6 flex flex-wrap gap-4">
      <a
        href="/blog"
        class="border border-[var(--rule)] px-6 py-3 font-medium transition-colors hover:bg-[var(--accent)] hover:text-[var(--accent-fg)]"
        >Read the blog →</a
      >
      <a
        href="/about"
        class="border border-[var(--rule)]/30 px-6 py-3 font-medium transition-colors hover:border-[var(--rule)]"
        >About me</a
      >
    </div>
  </section>

  {/* ─── Recent posts ─────────────────────────────────────── */}
  <section>
    <div class="flex items-baseline justify-between border-b-2 border-[var(--rule)] pb-3">
      <h2 class="kicker">Latest writing</h2>
      <a href="/blog" class="kicker link-underline">view all →</a>
    </div>

    {
      posts.length === 0 ? (
        <p class="py-12 text-[var(--fg-muted)]">
          No posts yet — the first one is coming soon.
        </p>
      ) : (
        <div>
          {posts.map((post, i) => (
            <PostCard post={post} index={i + 1} />
          ))}
        </div>
      )
    }
  </section>
</BaseLayout>

<style>
  /* Subtle staggered entrance for the hero wordmark lines. */
  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(0.5em);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  h1 span {
    animation: rise 0.6s cubic-bezier(0.2, 0.8, 0.2, 1) both;
  }
  h1 span:nth-child(2) {
    animation-delay: 0.08s;
  }
  h1 span:nth-child(3) {
    animation-delay: 0.16s;
  }
  .hero-write {
    position: relative;
  }
</style>

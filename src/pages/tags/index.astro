---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTagMap, tagSlug } from '../../utils/posts';

const tagMap = await getTagMap();
const tags = [...tagMap.entries()].sort((a, b) => b[1].length - a[1].length);
---

<BaseLayout
  title="Tags"
  description="Browse posts by topic."
>
  <header class="border-b-2 border-[var(--rule)] pb-6">
    <p class="kicker">{`${tags.length} topic${tags.length === 1 ? '' : 's'}`}</p>
    <h1 class="mt-3 text-5xl font-bold tracking-tight sm:text-7xl">Tags</h1>
  </header>

  {
    tags.length === 0 ? (
      <p class="py-12 text-[var(--fg-muted)]">No tags yet.</p>
    ) : (
      <ul class="flex flex-wrap gap-3 py-10">
        {tags.map(([tag, posts]) => (
          <li>
            <a
              href={`/tags/${tagSlug(tag)}/`}
              class="group flex items-baseline gap-2 border border-[var(--rule)]/40 px-4 py-2 text-lg transition-colors hover:bg-[var(--accent)] hover:text-[var(--accent-fg)]"
            >
              <span class="font-medium">#{tag}</span>
              <span class="font-mono text-sm opacity-60">{posts.length}</span>
            </a>
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>

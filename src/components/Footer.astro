---
import { SITE } from '../config';
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-[var(--rule)]/30">
  <div
    class="mx-auto flex max-w-6xl flex-col gap-6 px-5 py-10 sm:flex-row sm:items-end sm:justify-between sm:px-8"
  >
    <div>
      <p class="text-2xl font-bold tracking-tight">{SITE.title}</p>
      <p class="kicker mt-2">© {year} — all rights reserved</p>
    </div>
    <ul class="flex flex-wrap gap-5">
      {
        SITE.social.map((item) => (
          <li>
            <a
              href={item.href}
              class="kicker link-underline"
              rel="me noopener"
              target={item.href.startsWith('http') ? '_blank' : undefined}
            >
              {item.label} ↗
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</footer>

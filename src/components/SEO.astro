---
import { SITE } from '../config';

interface Props {
  /** Clean page title (no site name). Omit on the home page. */
  title?: string;
  description: string;
  /** 'website' for pages, 'article' for blog posts */
  type?: 'website' | 'article';
  image?: string;
  publishedTime?: Date;
  modifiedTime?: Date;
  tags?: string[];
}

const {
  title,
  description,
  type = 'website',
  image = SITE.defaultImage,
  publishedTime,
  modifiedTime,
  tags = [],
} = Astro.props;

// Clean title for og/JSON-LD; suffixed title for the <title> tag.
const cleanTitle = title ?? SITE.title;
const documentTitle = title ? `${title} — ${SITE.title}` : SITE.title;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(image, Astro.site).href;

const jsonLd =
  type === 'article'
    ? {
        '@context': 'https://schema.org',
        '@type': 'BlogPosting',
        headline: cleanTitle,
        description,
        image: ogImage,
        url: canonical,
        datePublished: publishedTime?.toISOString(),
        dateModified: (modifiedTime ?? publishedTime)?.toISOString(),
        keywords: tags.join(', '),
        author: { '@type': 'Person', name: SITE.author },
        publisher: { '@type': 'Person', name: SITE.author },
        mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
      }
    : {
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: SITE.title,
        description: SITE.description,
        url: Astro.site?.href,
        author: { '@type': 'Person', name: SITE.author },
      };
---

<title>{documentTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:title" content={cleanTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:site_name" content={SITE.title} />
{publishedTime && (
  <meta property="article:published_time" content={publishedTime.toISOString()} />
)}
{modifiedTime && (
  <meta property="article:modified_time" content={modifiedTime.toISOString()} />
)}
{tags.map((tag) => <meta property="article:tag" content={tag} />)}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={cleanTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
{SITE.twitter && <meta name="twitter:creator" content={SITE.twitter} />}

<script
  type="application/ld+json"
  set:html={JSON.stringify(jsonLd)}
/>

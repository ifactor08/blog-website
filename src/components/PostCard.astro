---
import type { Post } from '../utils/posts';
import { formatDate, isoDate, tagSlug } from '../utils/posts';

interface Props {
  post: Post;
  /** 1-based index for the editorial numbering (01, 02, …). */
  index: number;
}

const { post, index } = Astro.props;
const { title, description, pubDate, tags } = post.data;
const num = String(index).padStart(2, '0');
---

<article
  class="group grid grid-cols-[auto_1fr] gap-x-5 gap-y-2 border-t border-[var(--rule)]/30 py-7 sm:grid-cols-[5rem_1fr_auto] sm:gap-x-8"
>
  <span
    class="font-mono text-sm text-[var(--fg-muted)] transition-colors group-hover:text-[var(--accent)]"
    >{num}</span
  >

  <div class="min-w-0">
    <a href={`/blog/${post.id}/`} class="block">
      <h2
        class="text-2xl font-bold leading-tight tracking-tight transition-colors group-hover:text-[var(--accent)] sm:text-3xl"
      >
        {title}
      </h2>
      <p class="mt-2 max-w-2xl text-[var(--fg-muted)]">{description}</p>
    </a>
    {
      tags.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-2">
          {tags.map((tag) => (
            <a
              href={`/tags/${tagSlug(tag)}/`}
              class="kicker border border-[var(--rule)]/30 px-2 py-0.5 hover:border-[var(--accent)] hover:text-[var(--accent)]"
            >
              #{tag}
            </a>
          ))}
        </div>
      )
    }
  </div>

  <time
    datetime={isoDate(pubDate)}
    class="kicker col-start-2 sm:col-start-3 sm:text-right"
  >
    {formatDate(pubDate)}
  </time>
</article>

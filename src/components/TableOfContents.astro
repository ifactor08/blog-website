---
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}

// Only h2/h3 make a useful outline; h1 is the post title, h4+ is too granular.
const toc = Astro.props.headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{
  toc.length >= 3 && (
    <nav class="toc" aria-label="Table of contents">
      <p class="kicker mb-4">On this page</p>
      <ul class="space-y-1 border-l border-[var(--rule)]/25">
        {toc.map((h) => (
          <li>
            <a
              href={`#${h.slug}`}
              data-toc-link={h.slug}
              class:list={[
                'toc-link -ml-px block border-l-2 border-transparent py-1 text-sm leading-snug text-[var(--fg-muted)] transition-colors hover:text-[var(--fg)]',
                h.depth === 3 ? 'pl-9' : 'pl-5',
              ]}
            >
              {h.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}

<style>
  .toc-link.is-active {
    color: var(--accent);
    border-color: var(--accent);
  }
</style>

<script>
  // Scroll-spy: highlight the TOC link for the section currently in view.
  const links = new Map<string, HTMLElement>();
  document.querySelectorAll<HTMLElement>('[data-toc-link]').forEach((el) => {
    links.set(el.dataset.tocLink!, el);
  });

  if (links.size > 0) {
    const headings = [...links.keys()]
      .map((id) => document.getElementById(id))
      .filter((el): el is HTMLElement => el !== null);

    let active = '';
    const setActive = (id: string) => {
      if (id === active) return;
      active = id;
      links.forEach((el, key) =>
        el.classList.toggle('is-active', key === id),
      );
    };

    const observer = new IntersectionObserver(
      (entries) => {
        // Pick the topmost heading that's intersecting near the top of the viewport.
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
        if (visible[0]?.target.id) setActive(visible[0].target.id);
      },
      { rootMargin: '-10% 0px -70% 0px', threshold: 0 },
    );

    headings.forEach((h) => observer.observe(h));
  }
</script>
